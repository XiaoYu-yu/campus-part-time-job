# Backend trial / prod-like environment example
#
# Copy values into your deployment environment or local shell.
# Do not commit real secrets.

# Spring profile
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cangqiong_takeaway
DB_USERNAME=replace-with-db-user
DB_PASSWORD=replace-with-db-password

# JWT
# Use a long random value in real deployment.
JWT_SECRET=replace-with-long-random-jwt-secret
JWT_EXPIRATION=86400000

# CORS
# Example: https://campus.example.com
APP_CORS_ALLOWED_ORIGINS=https://replace-with-frontend-domain.example.com

# Uploads
APP_UPLOAD_STORAGE_PATH=uploads/private/images/
