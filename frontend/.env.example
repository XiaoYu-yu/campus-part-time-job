# Frontend environment example
#
# Copy to frontend/.env.local for local demos, or inject these values in the
# deployment build environment. Do not commit real keys.

# API base path. Keep /api when frontend and backend share the same reverse proxy.
VITE_API_BASE_URL=/api

# Mock data remains disabled for the trial-operation build.
VITE_USE_MOCK=false

# Tencent Map JS SDK key.
# Local demos should place the real key in frontend/.env.local.
# Deployment should inject this through the build environment or secret manager.
VITE_TENCENT_MAP_KEY=replace-with-tencent-map-key

# Android build API base files:
# - .env.android-user / .env.android-parttime: emulator default, 10.0.2.2
# - .env.android-*-emulator: explicit emulator mode
# - .env.android-*-lan.example: copy to ignored .env.android-*-lan and set LAN IP
# - .env.android-*-public.example: copy to ignored .env.android-*-public and set HTTPS API base
