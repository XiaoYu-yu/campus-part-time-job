# Standalone Podman deployment example.
# Copy to .env or run init-env.sh. Never commit the generated .env.

DB_NAME=campus_standalone
DB_USERNAME=campus_app
DB_PASSWORD=replace-with-random-db-password
MYSQL_ROOT_PASSWORD=replace-with-random-root-password
DB_USE_SSL=false
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true
DB_MIGRATION_ENABLED=true
DB_FLYWAY_BASELINE_ON_MIGRATE=false
DB_FLYWAY_BASELINE_VERSION=14
APP_SEED_INTERNAL_TRIAL=1

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION=86400000
APP_CORS_ALLOWED_ORIGINS=http://your-standalone-host:18080

VITE_TENCENT_MAP_KEY=

MYSQL_PORT=13306
BACKEND_PORT=18081
FRONTEND_PORT=18080
