# Internal trial docker compose example
# Copy to deploy/internal-trial/.env before the first startup.

COMPOSE_PROJECT_NAME=campus-trial

# MySQL and backend ports are bound to 127.0.0.1 by docker-compose.yml.
# They are for server-local diagnostics or SSH tunnels, not public access.
MYSQL_PORT=3306
BACKEND_PORT=8080
FRONTEND_PORT=80

DB_NAME=cangqiong_takeaway
DB_USERNAME=campus_trial
DB_PASSWORD=replace-with-db-password
MYSQL_ROOT_PASSWORD=replace-with-root-password

JWT_SECRET=replace-with-long-random-jwt-secret
JWT_EXPIRATION=86400000
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

VITE_TENCENT_MAP_KEY=replace-with-tencent-map-key
